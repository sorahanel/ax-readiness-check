rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /ax_assessments/{docId} {
      allow create: if request.resource.data.keys().hasAll(['createdAt','mode','answers'])
                    && request.resource.data.mode in ['SIMPLE','DETAILED'];
      allow read, update, delete: if false;  // 조회는 콘솔/관리자만
    }
  }
}
